---
import Layout from "../layouts/Layout.astro";

const certifications = [
  "Construction Business Consultant",
  "Business Consultant",
  "Case Management",
  "Inventory & Order Management",
  "Fixed Assets",
  "REST API Integration Developer",
  "Implementation Project Manager",
  "OData Integration Developer",
  "Project Accounting",
  "Technical Specialist",
];
---

<Layout title="About" description="AcuMaven — over 25 years of enterprise software expertise, 11 Acumatica certifications, and an official Celigo partnership.">
  <!-- Hero -->
  <section class="bg-navy pt-32 pb-16 lg:pt-40 lg:pb-20">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="max-w-3xl">
        <p class="text-teal font-semibold text-sm tracking-wide uppercase mb-4">About AcuMaven</p>
        <h1 class="text-4xl lg:text-5xl font-extrabold text-white mb-6">
          Deep expertise.<br />
          <span class="text-teal">Real-world results.</span>
        </h1>
        <p class="text-lg text-slate-300 leading-relaxed">
          AcuMaven is an Acumatica ERP consulting firm built on over 25 years
          of enterprise software experience, 11 certifications, and a track record
          of delivering implementations that actually work.
        </p>
      </div>
    </div>
  </section>

  <!-- What We Bring -->
  <section class="py-20 lg:py-28">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-16">
        <div class="lg:col-span-3">
          <h2 class="text-3xl font-extrabold text-navy mb-6">What sets us apart</h2>
          <div class="space-y-5 text-text-muted leading-relaxed">
            <p>
              Too many ERP projects fail because of the gap between who sells the project
              and who actually delivers it. Large firms pass clients through layers of
              project managers and junior consultants — and the expertise that won the
              deal disappears after the contract is signed.
            </p>
            <p>
              AcuMaven was founded to fix that. We bring senior-level expertise to every
              phase of your project — from scoping and architecture through go-live and
              ongoing support. No hand-offs, no learning curves, no surprises.
            </p>
            <p>
              With over 25 years in enterprise software and 11 active Acumatica
              certifications, we specialize in construction, field service, manufacturing,
              and distribution. We've delivered successful implementations, rescued
              stalled projects, and built integrations that companies depend on every day.
            </p>
            <p>
              As an official Celigo partner, we also bring deep integration expertise —
              connecting Acumatica to CRMs, ecommerce platforms, shipping, payroll,
              and legacy systems with solutions built to be reliable, not fragile.
            </p>
          </div>
        </div>

        <div class="lg:col-span-2">
          <div class="bg-gray-warm rounded-2xl p-8 lg:p-10 sticky top-28">
            <h3 class="font-bold text-navy mb-6">By the numbers</h3>

            <div class="space-y-5 mb-8">
              <div class="flex items-center gap-4">
                <span class="text-2xl font-extrabold text-teal w-12">25+</span>
                <span class="text-sm text-text-muted">years of enterprise software experience</span>
              </div>
              <div class="flex items-center gap-4">
                <span class="text-2xl font-extrabold text-teal w-12">11</span>
                <span class="text-sm text-text-muted">Acumatica certifications</span>
              </div>
              <div class="flex items-center gap-4">
                <span class="text-2xl font-extrabold text-teal w-12">4</span>
                <span class="text-sm text-text-muted">industry verticals served</span>
              </div>
            </div>

            <hr class="border-slate-200 mb-6" />

            <div class="flex items-center gap-4 mb-8">
              <img src="/celigo-partner-badge.svg" alt="Celigo Certified Partner" class="w-14 h-auto shrink-0" />
              <span class="text-sm font-medium text-navy">Official Celigo Partner</span>
            </div>

            <a
              href="/contact"
              class="w-full inline-flex items-center justify-center px-6 py-3 text-sm font-semibold rounded-lg bg-teal text-white hover:bg-teal-dark transition-colors duration-200"
            >
              Get in Touch
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Industries -->
  <section class="py-20 lg:py-28 bg-gray-warm">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="max-w-2xl mb-12">
        <p class="text-teal font-semibold text-sm tracking-wide uppercase mb-3">Industries We Serve</p>
        <h2 class="text-3xl font-extrabold text-navy">Focused expertise where it matters most.</h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="p-6 bg-white rounded-xl border border-slate-200">
          <h3 class="font-bold text-navy mb-2">Construction</h3>
          <p class="text-sm text-text-muted">Project accounting, job costing, compliance, subcontractor management, and AIA billing.</p>
        </div>
        <div class="p-6 bg-white rounded-xl border border-slate-200">
          <h3 class="font-bold text-navy mb-2">Field Service</h3>
          <p class="text-sm text-text-muted">Dispatch, scheduling, mobile workforce management, and service contract tracking.</p>
        </div>
        <div class="p-6 bg-white rounded-xl border border-slate-200">
          <h3 class="font-bold text-navy mb-2">Manufacturing</h3>
          <p class="text-sm text-text-muted">Production orders, BOM management, MRP, shop floor control, and inventory optimization.</p>
        </div>
        <div class="p-6 bg-white rounded-xl border border-slate-200">
          <h3 class="font-bold text-navy mb-2">Distribution</h3>
          <p class="text-sm text-text-muted">Warehouse management, order fulfillment, demand planning, and logistics coordination.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Certifications -->
  <section class="py-20 lg:py-28">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="max-w-2xl mb-12">
        <p class="text-teal font-semibold text-sm tracking-wide uppercase mb-3">Credentials</p>
        <h2 class="text-3xl font-extrabold text-navy">11 Acumatica Certifications</h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {certifications.map((cert) => (
          <div class="flex items-center gap-3 p-4 bg-gray-warm rounded-xl border border-slate-200">
            <svg class="w-5 h-5 text-teal shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            <span class="text-sm font-medium text-navy">{cert}</span>
          </div>
        ))}
        <div class="flex items-center gap-3 p-4 bg-teal/5 rounded-xl border border-teal/20">
          <svg class="w-5 h-5 text-teal shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          <span class="text-sm font-medium text-teal">Official Celigo Partner</span>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 lg:py-28 bg-navy">
    <div class="mx-auto max-w-7xl px-6 lg:px-8 text-center">
      <h2 class="text-3xl lg:text-4xl font-extrabold text-white mb-4">
        Let's talk about your project.
      </h2>
      <p class="text-slate-300 text-lg max-w-xl mx-auto mb-10">
        No sales pitch. No discovery committee. Just a straightforward
        conversation about what you need and how we can help.
      </p>
      <a
        href="/contact"
        class="inline-flex items-center justify-center px-8 py-4 text-base font-semibold rounded-lg bg-teal text-white hover:bg-teal-dark transition-colors duration-200"
      >
        Get in Touch
      </a>
    </div>
  </section>
</Layout>
