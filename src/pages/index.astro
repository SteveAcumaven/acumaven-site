---
import Base from '../layouts/Base.astro';
---
<Base title="Acumatica ERP Consulting — Implementation, Rescue, Integration">

  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <h1>Acumatica Done Right.<br/><em>Or Fixed Fast.</em></h1>
      <p>Implementation. Rescue. Integration. For companies that can't afford to get ERP wrong.</p>
      <a href="#contact" class="btn-primary">Talk to Steve</a>
      <a href="/services" class="btn-secondary">See what we do</a>
    </div>
  </section>

  <!-- Proof / Stats -->
  <div class="proof-bar">
    <div class="container">
      <div class="stats-grid">
        <div class="stat-block">
          <span class="stat-number">11</span>
          <span class="stat-label">Acumatica Certifications</span>
        </div>
        <div class="stat-block">
          <span class="stat-number">20+</span>
          <span class="stat-label">Implementations Delivered</span>
        </div>
        <div class="stat-block">
          <span class="stat-number">3</span>
          <span class="stat-label">Trades Served — HVAC, Plumbing, Electrical</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Client Industries -->
  <div class="industries-strip">
    <div class="container">
      <h3>Industries We Serve</h3>
      <div class="industries-list">
        <span class="industry-tag">Construction</span>
        <span class="industry-tag">Field Service</span>
        <span class="industry-tag">Manufacturing</span>
        <span class="industry-tag">Distribution</span>
      </div>
    </div>
  </div>

  <!-- Services -->
  <section id="services">
    <div class="container">
      <h2>What We Do</h2>
      <p class="section-sub">Acumatica expertise built around the companies that can't afford ERP failure.</p>
      <div class="services-grid">
        <div class="service-card">
          <h3>🏗️ Acumatica Implementation</h3>
          <p>New deployments for construction, field service, and manufacturing companies. Full project lifecycle from discovery through go-live.</p>
        </div>
        <div class="service-card">
          <h3>🚨 Rescue Projects</h3>
          <p>Takes over failed or stalled implementations. We know what went wrong and the fastest path from broken to working.</p>
        </div>
        <div class="service-card">
          <h3>🔁 Integration Development</h3>
          <p>Celigo, Boomi, REST API. Connects Acumatica to your tech stack — integrations that hold up in production.</p>
        </div>
        <div class="service-card">
          <h3>🤝 Ongoing Support</h3>
          <p>Post-go-live support, training, customization, and performance tuning. A real partner, not a help desk ticket.</p>
        </div>
      </div>
      <p style="margin-top: 2rem; text-align: center;"><a href="/services" class="btn-primary">Full Services Overview</a></p>
    </div>
  </section>

  <!-- Celigo callout -->
  <section style="padding: 0 0 4rem;">
    <div class="container">
      <div class="celigo-block">
        <h2>Official Celigo Partner</h2>
        <p>One of a select group of Acumatica consultants with Celigo certification. We don't just connect systems — we design integration logic that holds up in production.</p>
        <div class="celigo-chips">
          <span class="chip">HubSpot</span>
          <span class="chip">Shopify</span>
          <span class="chip">Salesforce</span>
          <span class="chip">Magento</span>
          <span class="chip">Amazon</span>
          <span class="chip">B2B Commerce</span>
          <span class="chip">Bi-directional sync</span>
          <span class="chip">Webhook flows</span>
        </div>
        <a href="/celigo" class="btn-primary">Explore Celigo Integration →</a>
      </div>
    </div>
  </section>

  <!-- Why AcuMaven -->
  <section style="background: var(--light);">
    <div class="container">
      <h2>Why AcuMaven</h2>
      <p class="section-sub">There are dozens of Acumatica partners. Here's what's different.</p>
      <div class="services-grid">
        <div class="service-card" style="border-left-color: var(--navy);">
          <h3>You talk to Steve — not a coordinator</h3>
          <p>No account managers, no hand-offs to junior consultants. The person who scopes your project is the person who implements it.</p>
        </div>
        <div class="service-card" style="border-left-color: var(--navy);">
          <h3>Field service is our vertical, not a checkbox</h3>
          <p>We specialize in companies with field technicians, dispatch, service orders, and job costing. We know the edge cases your last partner called customizations.</p>
        </div>
        <div class="service-card" style="border-left-color: var(--navy);">
          <h3>We take rescue projects</h3>
          <p>Most partners won't touch someone else's broken implementation. We've built a practice around fixing them — and we know what to look for fast.</p>
        </div>
        <div class="service-card" style="border-left-color: var(--navy);">
          <h3>Celigo certified — one of few</h3>
          <p>We're an official Celigo partner. When your ERP needs to connect to something, we build integrations that hold up — not ones that break silently at 2 AM.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- About -->
  <section id="about">
    <div class="container">
      <h2>About AcuMaven</h2>
      <p class="section-sub">Boutique practice. Real expertise. No account managers between you and the consultant doing the work.</p>
      <p style="max-width:680px; color: var(--muted);">AcuMaven was founded by Steve Milner — ex-military, 20+ years in business software, Acumatica specialist with 11 active certifications. We work with companies that need an ERP partner who actually knows the software, understands their industry, and shows up after go-live.<br/><br/>
      <a href="/about">Learn more about Steve and AcuMaven →</a></p>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact">
    <div class="container">
      <h2>Talk to Steve</h2>
      <p class="section-sub">Tell us what's broken — or what you're building. Either way, you'll get a straight answer in 24 hours.</p>
      <div class="contact-form">
        <form action="mailto:steve@acumaveninc.com" method="GET" enctype="text/plain">
          <label>Name</label>
          <input type="text" name="name" required />
          <label>Company</label>
          <input type="text" name="company" required />
          <label>Email</label>
          <input type="email" name="email" required />
          <label>What do you need help with?</label>
          <textarea name="message" placeholder="Describe your situation — new implementation, rescue project, integration, upgrade, or something else..." required></textarea>
          <button type="submit">Send it →</button>
        </form>
        <p style="font-size:0.82rem; color: var(--muted); margin-top:0.75rem; text-align:center;">Or email directly: <a href="mailto:steve@acumaveninc.com">steve@acumaveninc.com</a></p>
      </div>
    </div>
  </section>

</Base>
