---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Acumatica Done Right. Or Fixed Fast.">
  <!-- Hero -->
  <section class="relative bg-navy pt-32 pb-20 lg:pt-40 lg:pb-28 overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_rgba(79,184,178,0.12),_transparent_60%)]"></div>
    <div class="relative mx-auto max-w-7xl px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <!-- Logo Mark -->
        <div class="hidden lg:flex items-center justify-center">
          <div class="relative">
            <div class="absolute -inset-8 rounded-full bg-teal/5 blur-2xl"></div>
            <img
              src="/logo-white.svg"
              alt="AcuMaven"
              class="relative w-72 h-72 xl:w-80 xl:h-80 object-contain opacity-95"
            />
          </div>
        </div>

        <!-- Content -->
        <div>
          <p class="text-teal font-semibold text-sm tracking-wide uppercase mb-4">Acumatica ERP Consulting</p>
          <h1 class="text-4xl md:text-5xl lg:text-5xl xl:text-6xl font-extrabold text-white leading-[1.08] mb-6">
            Acumatica Done Right.<br />
            <span class="text-teal">Or Fixed Fast.</span>
          </h1>
          <p class="text-lg lg:text-xl text-slate-300 leading-relaxed max-w-2xl mb-10">
            Implementation. Rescue. Integration. Ongoing support.
            Deep Acumatica expertise backed by 26 years of enterprise software
            delivery and 11 active certifications.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a
              href="/contact"
              class="inline-flex items-center justify-center px-7 py-3.5 text-sm font-semibold rounded-lg bg-teal text-white hover:bg-teal-dark transition-colors duration-200"
            >
              Schedule a Consultation
            </a>
            <a
              href="/services"
              class="inline-flex items-center justify-center px-7 py-3.5 text-sm font-semibold rounded-lg border border-white/20 text-white hover:bg-white/5 transition-colors duration-200"
            >
              View Services
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Credential Bar -->
  <section class="bg-navy-light border-t border-white/5">
    <div class="mx-auto max-w-7xl px-6 lg:px-8 py-6">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
        <div class="text-center">
          <p class="text-2xl lg:text-3xl font-extrabold text-white">26</p>
          <p class="text-xs text-slate-400 mt-1 uppercase tracking-wide">Years Experience</p>
        </div>
        <div class="text-center">
          <p class="text-2xl lg:text-3xl font-extrabold text-white">11</p>
          <p class="text-xs text-slate-400 mt-1 uppercase tracking-wide">Certifications</p>
        </div>
        <div class="text-center">
          <p class="text-2xl lg:text-3xl font-extrabold text-teal">4</p>
          <p class="text-xs text-slate-400 mt-1 uppercase tracking-wide">Industry Verticals</p>
        </div>
        <div class="text-center">
          <p class="text-2xl lg:text-3xl font-extrabold text-white flex items-center justify-center gap-1.5">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </p>
          <p class="text-xs text-slate-400 mt-1 uppercase tracking-wide">Celigo Partner</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="py-20 lg:py-28">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="max-w-2xl mb-16">
        <p class="text-teal font-semibold text-sm tracking-wide uppercase mb-3">What We Do</p>
        <h2 class="text-3xl lg:text-4xl font-extrabold text-navy">
          End-to-end Acumatica expertise.
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
        <a href="/services#implementation" class="group block p-8 lg:p-10 rounded-2xl border border-slate-200 hover:border-teal/30 hover:shadow-lg hover:shadow-teal/5 transition-all duration-300">
          <div class="w-10 h-10 rounded-lg bg-teal/10 flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </div>
          <h3 class="text-xl font-bold text-navy mb-3 group-hover:text-teal transition-colors">Implementation</h3>
          <p class="text-text-muted text-sm leading-relaxed">
            New Acumatica deployments for construction, field service, manufacturing, and distribution. Scoped right, delivered on time, with no surprises.
          </p>
        </a>

        <a href="/services#rescue" class="group block p-8 lg:p-10 rounded-2xl border border-slate-200 hover:border-teal/30 hover:shadow-lg hover:shadow-teal/5 transition-all duration-300">
          <div class="w-10 h-10 rounded-lg bg-teal/10 flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99" /></svg>
          </div>
          <h3 class="text-xl font-bold text-navy mb-3 group-hover:text-teal transition-colors">Rescue Projects</h3>
          <p class="text-text-muted text-sm leading-relaxed">
            Failed or stalled implementation? We take over where others left off. Diagnose what went wrong, fix it, and get you live.
          </p>
        </a>

        <a href="/services#integration" class="group block p-8 lg:p-10 rounded-2xl border border-slate-200 hover:border-teal/30 hover:shadow-lg hover:shadow-teal/5 transition-all duration-300">
          <div class="w-10 h-10 rounded-lg bg-teal/10 flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m9.193-9.193a4.5 4.5 0 00-6.364 0l-4.5 4.5a4.5 4.5 0 001.242 7.244" /></svg>
          </div>
          <h3 class="text-xl font-bold text-navy mb-3 group-hover:text-teal transition-colors">Integration</h3>
          <p class="text-text-muted text-sm leading-relaxed">
            Connect Acumatica to your CRM, ecommerce, WMS, or anything else. Celigo, REST APIs, and OData — built to be reliable, not fragile.
          </p>
        </a>

        <a href="/services#support" class="group block p-8 lg:p-10 rounded-2xl border border-slate-200 hover:border-teal/30 hover:shadow-lg hover:shadow-teal/5 transition-all duration-300">
          <div class="w-10 h-10 rounded-lg bg-teal/10 flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
          </div>
          <h3 class="text-xl font-bold text-navy mb-3 group-hover:text-teal transition-colors">Ongoing Support</h3>
          <p class="text-text-muted text-sm leading-relaxed">
            Post-go-live training, customization, and troubleshooting. A real partner who picks up the phone — not a ticket queue.
          </p>
        </a>
      </div>
    </div>
  </section>

  <!-- Why AcuMaven -->
  <section class="py-20 lg:py-28 bg-gray-warm">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">
        <div>
          <p class="text-teal font-semibold text-sm tracking-wide uppercase mb-3">Why AcuMaven</p>
          <h2 class="text-3xl lg:text-4xl font-extrabold text-navy mb-6">
            You deserve a consultant who's done this before.
          </h2>
          <p class="text-text-muted leading-relaxed mb-8">
            Most firms assign you a project manager who delegates to junior consultants.
            At AcuMaven, you work directly with Steve — a 26-year veteran with
            11 Acumatica certifications who has personally delivered implementations
            across construction, field service, manufacturing, and distribution.
          </p>
          <p class="text-text-muted leading-relaxed">
            That means faster answers, fewer mistakes, and no one learning
            on your dime. If something goes wrong, there's no escalation chain —
            you already have the person who can fix it.
          </p>
        </div>

        <div class="space-y-5">
          <div class="p-6 rounded-xl bg-white border border-slate-200">
            <h3 class="font-bold text-navy mb-2">No hand-offs</h3>
            <p class="text-sm text-text-muted">The person who scopes your project is the same person who builds it. No telephone game between sales and delivery.</p>
          </div>
          <div class="p-6 rounded-xl bg-white border border-slate-200">
            <h3 class="font-bold text-navy mb-2">Rescue-ready</h3>
            <p class="text-sm text-text-muted">We take on the projects other firms won't touch. Failed go-live? Stalled implementation? We've seen it, fixed it, shipped it.</p>
          </div>
          <div class="p-6 rounded-xl bg-white border border-slate-200">
            <h3 class="font-bold text-navy mb-2">Celigo certified</h3>
            <p class="text-sm text-text-muted">One of few consultants with both deep Acumatica expertise and official Celigo partnership for enterprise integrations.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Industries -->
  <section class="py-20 lg:py-28">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="max-w-2xl mx-auto text-center mb-16">
        <p class="text-teal font-semibold text-sm tracking-wide uppercase mb-3">Industries</p>
        <h2 class="text-3xl lg:text-4xl font-extrabold text-navy">
          Built for businesses that build things.
        </h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="text-center p-8 rounded-2xl bg-gray-warm">
          <div class="w-12 h-12 rounded-xl bg-teal/10 flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3H21m-3.75 3H21" /></svg>
          </div>
          <h3 class="font-bold text-navy mb-1">Construction</h3>
          <p class="text-xs text-text-muted">Project accounting, job costing, compliance</p>
        </div>

        <div class="text-center p-8 rounded-2xl bg-gray-warm">
          <div class="w-12 h-12 rounded-xl bg-teal/10 flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17l-5.66-5.66a8 8 0 1111.31 0l-5.65 5.66zm0 0L12 21m-1.17-2.34L9 21m3-3.5l1.83 3.5M3.5 14.5h1M19.5 14.5h1M12 3v1" /></svg>
          </div>
          <h3 class="font-bold text-navy mb-1">Field Service</h3>
          <p class="text-xs text-text-muted">Dispatch, scheduling, mobile workforce</p>
        </div>

        <div class="text-center p-8 rounded-2xl bg-gray-warm">
          <div class="w-12 h-12 rounded-xl bg-teal/10 flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12a7.5 7.5 0 0015 0m-15 0a7.5 7.5 0 1115 0m-15 0H3m16.5 0H21m-1.5 0H12m-8.457 3.077l1.41-.513m14.095-5.13l1.41-.513M5.106 17.785l1.15-.964m11.49-9.642l1.149-.964M7.501 19.795l.75-1.3m7.5-12.99l.75-1.3m-6.063 16.658l.26-1.477m2.605-14.772l.26-1.477m0 17.726l-.26-1.477M10.698 4.614l-.26-1.477M16.5 19.794l-.75-1.299M7.5 4.205L6.75 2.906" /></svg>
          </div>
          <h3 class="font-bold text-navy mb-1">Manufacturing</h3>
          <p class="text-xs text-text-muted">Production orders, BOM, inventory control</p>
        </div>

        <div class="text-center p-8 rounded-2xl bg-gray-warm">
          <div class="w-12 h-12 rounded-xl bg-teal/10 flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" /></svg>
          </div>
          <h3 class="font-bold text-navy mb-1">Distribution</h3>
          <p class="text-xs text-text-muted">Warehouse, order management, logistics</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 lg:py-28 bg-navy">
    <div class="mx-auto max-w-7xl px-6 lg:px-8 text-center">
      <h2 class="text-3xl lg:text-4xl font-extrabold text-white mb-4">
        Ready to get Acumatica right?
      </h2>
      <p class="text-slate-300 text-lg max-w-xl mx-auto mb-10">
        Whether it's a new implementation, a rescue, or an integration —
        let's start with a conversation.
      </p>
      <a
        href="/contact"
        class="inline-flex items-center justify-center px-8 py-4 text-base font-semibold rounded-lg bg-teal text-white hover:bg-teal-dark transition-colors duration-200"
      >
        Get in Touch
      </a>
    </div>
  </section>
</Layout>
