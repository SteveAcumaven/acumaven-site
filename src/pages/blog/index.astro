---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Blog" description="Insights on Acumatica ERP implementation, integration, and best practices from a 25+ year veteran.">
  <!-- Hero -->
  <section class="bg-navy pt-32 pb-16 lg:pt-40 lg:pb-20">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="max-w-3xl">
        <p class="text-teal font-semibold text-sm tracking-wide uppercase mb-4">Blog</p>
        <h1 class="text-4xl lg:text-5xl font-extrabold text-white mb-6">
          From the field.
        </h1>
        <p class="text-lg text-slate-300 leading-relaxed">
          Practical insights on Acumatica implementation, integration,
          and what actually works in the real world.
        </p>
      </div>
    </div>
  </section>

  <!-- Blog Content -->
  <section class="py-20 lg:py-28">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="max-w-2xl mx-auto text-center">
        <div class="w-16 h-16 rounded-2xl bg-teal/10 flex items-center justify-center mx-auto mb-6">
          <svg class="w-8 h-8 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 01-2.25 2.25M16.5 7.5V18a2.25 2.25 0 002.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 002.25 2.25h13.5M6 7.5h3v3H6v-3z" /></svg>
        </div>
        <h2 class="text-2xl font-bold text-navy mb-3">Posts coming soon.</h2>
        <p class="text-text-muted leading-relaxed mb-8">
          I'm working on writing up some of the patterns and lessons
          I've learned over 25+ years of ERP work. Check back soon.
        </p>
        <a
          href="/contact"
          class="inline-flex items-center justify-center px-6 py-3 text-sm font-semibold rounded-lg bg-teal text-white hover:bg-teal-dark transition-colors duration-200"
        >
          Get in touch instead
        </a>
      </div>
    </div>
  </section>
</Layout>
