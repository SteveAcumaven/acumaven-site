---
import Layout from "../../layouts/Layout.astro";

const posts = [
  {
    slug: "2026-03-05-acumatica-implementation-failing",
    title: "5 Signs Your Acumatica Implementation Is Failing (And What to Do About It)",
    description: "Most failing implementations show the same warning signs early. Here's what to look for before it's too late.",
    date: "March 5, 2026",
  },
  {
    slug: "2026-03-05-celigo-vs-boomi-vs-mulesoft",
    title: "Celigo vs. Boomi vs. MuleSoft: Which Integration Platform Is Right for Mid-Market?",
    description: "Three platforms, very different trade-offs. We break down cost, complexity, and where each one actually makes sense.",
    date: "March 5, 2026",
  },
  {
    slug: "2026-03-05-what-to-ask-acumatica-consultant",
    title: "What to Ask Before Hiring an Acumatica Consultant",
    description: "The questions most companies don't think to ask — until after the project goes sideways.",
    date: "March 5, 2026",
  },
  {
    slug: "2026-01-15-ai-erp-business-software",
    title: "How AI Is Transforming ERP and Business Software",
    description: "What the AI wave actually means for mid-market ERP and where the real leverage is.",
    date: "January 15, 2026",
  },
];
---

<Layout title="Blog" description="Insights on Acumatica ERP implementation, integration, AI, and best practices from a 25+ year veteran.">
  <!-- Hero -->
  <section class="bg-navy pt-32 pb-16 lg:pt-40 lg:pb-20">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="max-w-3xl">
        <p class="text-teal font-semibold text-sm tracking-wide uppercase mb-4">Blog</p>
        <h1 class="text-4xl lg:text-5xl font-extrabold text-white mb-6">
          From the field.
        </h1>
        <p class="text-lg text-slate-300 leading-relaxed">
          Hard-won perspective on Acumatica, integrations, and what's coming next.
        </p>
      </div>
    </div>
  </section>

  <!-- Blog Posts -->
  <section class="py-20 lg:py-28">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
        {posts.map((post) => (
          <a href={`/blog/${post.slug}`} class="group block p-6 lg:p-8 rounded-2xl border border-slate-200 hover:border-teal/30 hover:shadow-lg hover:shadow-teal/5 transition-all duration-300">
            <p class="text-xs text-text-muted mb-3">{post.date}</p>
            <h2 class="text-lg font-bold text-navy mb-2 group-hover:text-teal transition-colors">{post.title}</h2>
            <p class="text-sm text-text-muted leading-relaxed">{post.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
