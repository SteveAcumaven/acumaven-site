---
export interface Props {
  title: string;
  description?: string;
}
const { title, description = "AcuMaven — Acumatica ERP consulting specialists for field service companies. New implementations, rescue projects, and Celigo integration." } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | AcuMaven</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles/global.css" />
</head>
<body>
  <nav>
    <div class="container">
      <a href="/" class="logo">Acu<span>Maven</span></a>
      <ul>
        <li><a href="/#services">Services</a></li>
        <li><a href="/celigo">Celigo</a></li>
        <li><a href="/blog">Blog</a></li>
        <li><a href="/#about">About</a></li>
        <li><a href="/#contact" class="cta-nav">Tell us what's broken</a></li>
      </ul>
      <button class="nav-toggle" aria-label="Toggle menu" onclick="this.nextElementSibling||0;document.querySelector('nav ul').classList.toggle('open')">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>
  <slot />
  <footer>
    <div class="container">
      <p><strong>AcuMaven Inc.</strong> &nbsp;·&nbsp; Acumatica ERP Consulting &nbsp;·&nbsp; Official Celigo Partner<br />
      San Clemente, CA &nbsp;·&nbsp; <a href="mailto:steve@acumaveninc.com" style="color:rgba(255,255,255,0.7)">steve@acumaveninc.com</a></p>
    </div>
  </footer>
</body>
</html>
